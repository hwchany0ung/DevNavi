# terraform.tfvars.example
# cp terraform.tfvars.example terraform.tfvars 후 값 입력
# ⚠️ terraform.tfvars는 .gitignore에 포함됨 (시크릿 포함)

aws_region  = "ap-northeast-2"
project     = "devnavi"
env         = "prod"
github_repo = "hwchany0ung/DevNavi"

# 1단계: 도메인 없이 먼저 배포 (CloudFront 기본 도메인으로 테스트)
domain_name = ""

# 2단계: 가비아에서 도메인 구매 + ACM 인증서 ISSUED 확인 후
# domain_name = "devnavi.kr"
# 입력 후 terraform apply 재실행 → CloudFront aliases + HTTPS 적용

# ── 시크릿 (절대 Git에 커밋하지 말 것) ──
anthropic_api_key    = "sk-ant-api03-..."
supabase_url         = "https://xxxx.supabase.co"
supabase_service_key = "eyJhbGciOiJIUzI1NiIs..."
supabase_anon_key    = "eyJhbGciOiJIUzI1NiIs..."
supabase_jwt_secret  = "your-jwt-secret"
